# 💓 Founder Heartbeat — Environment Configuration
# Copy this file to '.env' and fill in your real keys.
# You only need the keys for the providers you want to use.
# The system works fully in MOCK mode without any keys!

# ── AI Providers (pick one or more; system tries gemini → anthropic → openai) ──
# Free tier: https://aistudio.google.com/ → Get API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Paid: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Paid: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-key-here

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps → OAuth & Permissions
SLACK_TOKEN=xoxb-your-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0000/B0000/XXXX

# ── GitHub ────────────────────────────────────────────────────────────────────
# Settings → Developer Settings → Personal Access Tokens (classic)
GITHUB_TOKEN=ghp_your-personal-access-token

# ── Notion ────────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your-notion-integration-token

# ── Gmail (uses OAuth credentials.json, not a token here) ────────────────────
# Download credentials.json from Google Cloud Console → APIs → Gmail API
# Place it at: heartbeat/config/gmail_credentials.json

# ── Email Delivery (SMTP) ─────────────────────────────────────────────────────
# For Gmail: use an App Password (not your main password)
# https://myaccount.google.com/apppasswords
SMTP_USER=yourname@gmail.com
SMTP_PASS=your-app-password-here
SMTP_TO=founder@yourcompany.com

