# 💓 Founder Heartbeat - Example Configuration
# Copy this file to '.env' and fill in your real keys.

# --- Anthropic (AI Summarization) ---
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Slack (Connectors & Notifications) ---
# Create a Slack App and get these from your dashboard
SLACK_TOKEN=xoxb-your-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0000/B0000/XXXX

# --- Optional Connectors ---
NOTION_TOKEN=secret_your_notion_token
GITHUB_TOKEN=ghp_your_personal_access_token
